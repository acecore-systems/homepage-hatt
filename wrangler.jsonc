{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "homepage-hatt",
  "pages_build_output_dir": "./dist",
  "compatibility_date": "2026-06-07",
  "d1_databases": [
    {
      "binding": "COMMENTS_DB",
      "database_name": "homepage-hatt-comments",
      "database_id": "97d09eef-97fe-4d11-8c28-93bb40bfd234",
      "migrations_dir": "migrations",
    },
    {
      "binding": "SHOP_DB",
      "database_name": "homepage-hatt-shop",
      "database_id": "a79e27cc-a53c-47de-b464-7cab1218438e",
      "migrations_dir": "migrations/shop",
    },
  ],
  "r2_buckets": [
    {
      "binding": "SHOP_FILES",
      "bucket_name": "homepage-hatt-shop-files",
    },
  ],
  "vars": {
    "COMMENT_ALLOWED_HOSTNAMES": "hatt.acecore.net,www.hatt.acecore.net,homepage-hatt.pages.dev",
    "COURSE_SIGNUP_EMAIL_FROM": "Hattのホームページ <noreply@hatt.acecore.net>",
    "COURSE_SIGNUP_EMAIL_TO": "borubin@outlook.jp",
  },
  "services": [
    {
      "binding": "COURSE_EMAIL_SERVICE",
      "service": "homepage-hatt-course-email",
    },
  ],
  "env": {
    "preview": {
      "d1_databases": [
        {
          "binding": "COMMENTS_DB",
          "database_name": "homepage-hatt-comments",
          "database_id": "97d09eef-97fe-4d11-8c28-93bb40bfd234",
          "migrations_dir": "migrations",
        },
        {
          "binding": "SHOP_DB",
          "database_name": "homepage-hatt-shop",
          "database_id": "a79e27cc-a53c-47de-b464-7cab1218438e",
          "migrations_dir": "migrations/shop",
        },
      ],
      "r2_buckets": [
        {
          "binding": "SHOP_FILES",
          "bucket_name": "homepage-hatt-shop-files",
        },
      ],
      "vars": {
        "COMMENT_ALLOWED_HOSTNAMES": "hatt.acecore.net,www.hatt.acecore.net,homepage-hatt.pages.dev",
        "COURSE_SIGNUP_EMAIL_FROM": "Hattのホームページ <noreply@hatt.acecore.net>",
        "COURSE_SIGNUP_EMAIL_TO": "borubin@outlook.jp",
      },
      "services": [
        {
          "binding": "COURSE_EMAIL_SERVICE",
          "service": "homepage-hatt-course-email",
        },
      ],
    },
    "production": {
      "d1_databases": [
        {
          "binding": "COMMENTS_DB",
          "database_name": "homepage-hatt-comments",
          "database_id": "97d09eef-97fe-4d11-8c28-93bb40bfd234",
          "migrations_dir": "migrations",
        },
        {
          "binding": "SHOP_DB",
          "database_name": "homepage-hatt-shop",
          "database_id": "a79e27cc-a53c-47de-b464-7cab1218438e",
          "migrations_dir": "migrations/shop",
        },
      ],
      "r2_buckets": [
        {
          "binding": "SHOP_FILES",
          "bucket_name": "homepage-hatt-shop-files",
        },
      ],
      "vars": {
        "COMMENT_ALLOWED_HOSTNAMES": "hatt.acecore.net,www.hatt.acecore.net,homepage-hatt.pages.dev",
        "COURSE_SIGNUP_EMAIL_FROM": "Hattのホームページ <noreply@hatt.acecore.net>",
        "COURSE_SIGNUP_EMAIL_TO": "borubin@outlook.jp",
      },
      "services": [
        {
          "binding": "COURSE_EMAIL_SERVICE",
          "service": "homepage-hatt-course-email",
        },
      ],
    },
  },
}
