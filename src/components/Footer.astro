---
import { externalAttrs } from '@/utils/routes'

type Site = {
  name: string
  description: string
  socialLinks: { label: string; href: string }[]
}

const { site } = Astro.props as { site: Site }
---

<footer class="site-footer">
  <div class="footer-inner">
    <div class="footer-brand">
      <span class="brand-mark" aria-hidden="true">
        <span class="i-lucide-feather"></span>
      </span>
      <div>
        <p class="footer-title">{site.name}</p>
        <p class="footer-subtitle">hatt homepage</p>
      </div>
    </div>
    <div class="footer-description">
      <p>イラストや小説の制作記録をのんびり更新中。</p>
      <small>© 2025 Hatt</small>
    </div>
    <div class="footer-links">
      {
        site.socialLinks.map((link) => (
          <a href={link.href} {...externalAttrs(link.href)}>
            {link.label}
          </a>
        ))
      }
      <a href="/rss.xml">RSS</a>
    </div>
  </div>
</footer>
