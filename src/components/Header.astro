---
import { externalAttrs } from '@/utils/routes'

type Site = {
  name: string
  icon: string
  headerLinks: { label: string; href: string }[]
}

const { site } = Astro.props as { site: Site }

const iconByLabel: Record<string, string> = {
  絵: 'i-lucide-images',
  小説: 'i-lucide-book-open',
  '3D作品': 'i-lucide-box',
  ショップ: 'i-lucide-shopping-bag',
  講座: 'i-lucide-graduation-cap',
  動画: 'i-lucide-square-play',
  Acecore: 'i-lucide-arrow-up-right',
  ブログ: 'i-lucide-newspaper',
  モデリング: 'i-lucide-box',
  プロフィール: 'i-lucide-user-round',
}

const primaryNavLabels = new Set(['絵', '小説', '3D作品', 'ショップ'])
const primaryLinks = site.headerLinks.filter((link) =>
  primaryNavLabels.has(link.label),
)
const secondaryLinks = site.headerLinks.filter(
  (link) => !primaryNavLabels.has(link.label),
)
---

<header class="site-header">
  <nav class="site-nav" aria-label="メインナビゲーション">
    <a class="brand-link" href="/">
      <span class="brand-mark" aria-hidden="true">
        <span class="i-lucide-feather"></span>
      </span>
      <span class="brand-copy">
        <span class="brand-name">{site.name}</span>
        <span class="brand-subtitle">hatt homepage</span>
      </span>
    </a>
    <div class="nav-links">
      <button
        class="nav-search-button"
        type="button"
        data-search-open
        data-hatt-event="search_open"
        data-hatt-label="header_search"
        data-hatt-location="header"
        aria-controls="site-search-modal"
        aria-label="検索"
      >
        <span class="i-lucide-search" aria-hidden="true"></span>
      </button>
      {
        primaryLinks.map((link) => {
          const isExternal = link.href.startsWith('http')

          return (
            <a
              class:list={['nav-link', { 'nav-link--external': isExternal }]}
              href={link.href}
              {...externalAttrs(link.href)}
              data-hatt-event="nav_click"
              data-hatt-label={link.label}
              data-hatt-location="header"
            >
              <span
                class={iconByLabel[link.label] ?? 'i-lucide-arrow-right'}
                aria-hidden="true"
              />
              <span>{link.label}</span>
            </a>
          )
        })
      }
      {
        secondaryLinks.length > 0 && (
          <details class="nav-more">
            <summary
              class="nav-link nav-more-trigger"
              data-hatt-event="nav_more_open"
              data-hatt-label="その他"
              data-hatt-location="header"
              aria-label="その他のナビゲーション"
            >
              <span class="i-lucide-ellipsis" aria-hidden="true" />
              <span>その他</span>
            </summary>
            <div class="nav-more-menu">
              {secondaryLinks.map((link) => {
                const isExternal = link.href.startsWith('http')

                return (
                  <a
                    class:list={[
                      'nav-link',
                      { 'nav-link--external': isExternal },
                    ]}
                    href={link.href}
                    {...externalAttrs(link.href)}
                    data-hatt-event="nav_click"
                    data-hatt-label={link.label}
                    data-hatt-location="header_more"
                  >
                    <span
                      class={iconByLabel[link.label] ?? 'i-lucide-arrow-right'}
                      aria-hidden="true"
                    />
                    <span>{link.label}</span>
                  </a>
                )
              })}
            </div>
          </details>
        )
      }
      <a
        class="nav-link nav-cart-link nav-icon-link"
        href="/shop/cart/"
        data-hatt-event="nav_click"
        data-hatt-label="カート"
        data-hatt-location="header"
        aria-label="カート"
      >
        <span class="i-lucide-shopping-cart" aria-hidden="true"></span>
        <span class="sr-only">カート</span>
        <strong data-shop-cart-count hidden>0</strong>
      </a>
    </div>
  </nav>
</header>
