---
import BaseLayout from '@/layouts/BaseLayout.astro'
import CampaignNotices from '@/components/CampaignNotices.astro'
import { getAuthors, getSiteConfig } from '@/utils/blog'
import { externalAttrs } from '@/utils/routes'

const site = await getSiteConfig()
const [author] = await getAuthors()
---

<BaseLayout
  title="プロフィール"
  description="Hattの活動プロフィール。絵、小説、VRChat向け3Dアバター・ギミック制作について紹介します。"
>
  <section class="page-hero">
    <div class="narrow-page page-title">
      <div>
        <h1>プロフィール</h1>
        <p class="lead">{author.data.bio}</p>
      </div>
      <img
        src={author.data.avatar}
        alt={`${author.data.name}のプロフィール画像`}
        width="84"
        height="84"
        style="border-radius: 16px;"
      />
    </div>
  </section>

  <CampaignNotices placement="profile-after-hero" />

  <section class="section-band">
    <div class="narrow-page profile-grid">
      <article class="profile-card">
        <h2>絵</h2>
        <p>
          キャラクターや世界観の絵、設定メモ、制作中に考えたことを、ブログ記事や作品紹介として残していきます。
        </p>
        <a class="text-arrow" href="/art/">
          絵を見る
          <span class="i-lucide-arrow-right" aria-hidden="true"></span>
        </a>
      </article>
      <article class="profile-card">
        <h2>小説</h2>
        <p>
          小説投稿サイトで短編や連載を公開しています。物語づくりに関する記録も少しずつ置いていきます。
        </p>
        <a class="text-arrow" href="/novels/">
          小説一覧へ
          <span class="i-lucide-arrow-right" aria-hidden="true"></span>
        </a>
      </article>
      <article class="profile-card">
        <h2>モデリング</h2>
        <p>
          VRChat向けのオリジナル3Dアバター、ギミック、アクセサリーを制作しています。BOOTH、YouTube、Xで作品や制作の様子を公開しています。
        </p>
        <a class="text-arrow" href="/modeling/">
          モデリングを見る
          <span class="i-lucide-arrow-right" aria-hidden="true"></span>
        </a>
      </article>
      <article class="profile-card">
        <h2>外部リンク</h2>
        <div class="social-row">
          {
            author.data.links.map((link) => (
              <a href={link.href} {...externalAttrs(link.href)}>
                {link.label}
              </a>
            ))
          }
        </div>
      </article>
    </div>
  </section>
</BaseLayout>
