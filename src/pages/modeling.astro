---
import BaseLayout from '@/layouts/BaseLayout.astro'
import CampaignNotices from '@/components/CampaignNotices.astro'
import { getCollection } from 'astro:content'
import { getSiteConfig } from '@/utils/blog'
import { externalAttrs } from '@/utils/routes'

const site = await getSiteConfig()
const items = (await getCollection('modeling')).sort((a, b) => {
  if (a.data.featured === b.data.featured)
    return (
      a.data.order - b.data.order ||
      a.data.title.localeCompare(b.data.title, 'ja')
    )
  return a.data.featured ? -1 : 1
})
---

<BaseLayout
  title="モデリング"
  description="HattのVRChat向けオリジナル3Dアバター・ギミック制作と、YouTube・X・BOOTHへの導線です。"
  image="/uploads/hatt/modeling-preview.jpg"
>
  <section class="page-hero">
    <div class="section-inner modeling-feature">
      <div>
        <p class="hero-note">
          <span class="i-lucide-box" aria-hidden="true"></span>
          VRChat向けアバター・ギミック・アクセサリー
        </p>
        <h1>モデリング</h1>
        <p class="lead">
          BOOTHショップ「エースコア」で公開しているVRChat向け作品を、紹介動画・価格・特徴とあわせて整理しています。
          アバター本体、Modular
          Avatar対応ギミック、着替え演出アクセサリーまで、用途からたどれる入口です。
        </p>
        <div class="modeling-stats" aria-label="公開中のモデリング活動">
          <div>
            <span>アバター</span>
            <strong>9種</strong>
          </div>
          <div>
            <span>ギミック</span>
            <strong>5種</strong>
          </div>
          <div>
            <span>BOOTH</span>
            <strong>全14商品</strong>
          </div>
        </div>
        <div class="social-row" style="margin-top: 24px;">
          {
            site.socialLinks.map((link) => (
              <a href={link.href} {...externalAttrs(link.href)}>
                {link.label}
              </a>
            ))
          }
        </div>
      </div>
      <div class="modeling-preview">
        <img src="/uploads/hatt/modeling-preview.jpg" alt="" />
        <p>商品ページ、紹介動画、試着ワールドへの導線をまとめています</p>
      </div>
    </div>
  </section>

  <CampaignNotices placement="modeling-after-hero" />

  <section
    class="section-band modeling-overview"
    aria-labelledby="overview-title"
  >
    <div class="section-inner">
      <div class="section-heading">
        <div>
          <h2 id="overview-title">ここで確認できること</h2>
        </div>
        <p>
          商品ページへ移動する前に、用途、見どころ、導入前に見るべき情報をざっと確認できます。
        </p>
      </div>
      <div class="modeling-info-grid">
        <article>
          <span class="i-lucide-sparkles" aria-hidden="true"></span>
          <h3>作品の見どころ</h3>
          <p>
            アバターのコンセプト、ギミックの使い方、紹介動画で確認できる動きや演出を作品ごとに整理しています。
          </p>
        </article>
        <article>
          <span class="i-lucide-settings" aria-hidden="true"></span>
          <h3>導入前の確認</h3>
          <p>
            Modular Avatar、lilToon、Unity / VRChat SDK
            など、購入前に見ておきたい前提情報をまとめています。
          </p>
        </article>
        <article>
          <span class="i-lucide-route" aria-hidden="true"></span>
          <h3>試着と購入導線</h3>
          <p>
            BOOTH、YouTube、試着ワールド、関連作品を行き来しやすくし、気になった作品をすぐ確認できるようにしています。
          </p>
        </article>
      </div>
    </div>
  </section>

  <section class="section-band" aria-labelledby="lineup-title">
    <div class="section-inner">
      <div class="section-heading">
        <div>
          <h2 id="lineup-title">作品ラインアップ</h2>
        </div>
        <p>
          YouTube説明欄とBOOTH公開情報をもとに、作品ごとの特徴・価格・購入先・紹介動画を見比べられるようにしました。
        </p>
      </div>
      <div class="modeling-grid">
        {
          items.map((item) => (
            <article class="modeling-card">
              {item.data.image && (
                <div class="modeling-card-image">
                  <img
                    src={item.data.image}
                    alt={`${item.data.title}の紹介画像`}
                    loading="lazy"
                  />
                </div>
              )}
              <div>
                <span class="price-label">{item.data.kind}</span>
                <h3>{item.data.title}</h3>
              </div>
              <p>{item.data.summary}</p>
              {item.data.priceLabel && (
                <span class="price-label">{item.data.priceLabel}</span>
              )}
              {item.data.features.length > 0 && (
                <div class="modeling-detail-block">
                  <h4>主な特徴</h4>
                  <ul>
                    {item.data.features.map((feature) => (
                      <li>{feature}</li>
                    ))}
                  </ul>
                </div>
              )}
              {(item.data.specs.length > 0 ||
                item.data.requirements.length > 0) && (
                <div class="modeling-meta-grid">
                  {item.data.specs.length > 0 && (
                    <div>
                      <h4>商品情報</h4>
                      <ul>
                        {item.data.specs.map((spec) => (
                          <li>{spec}</li>
                        ))}
                      </ul>
                    </div>
                  )}
                  {item.data.requirements.length > 0 && (
                    <div>
                      <h4>対応・前提</h4>
                      <ul>
                        {item.data.requirements.map((requirement) => (
                          <li>{requirement}</li>
                        ))}
                      </ul>
                    </div>
                  )}
                </div>
              )}
              {item.data.related.length > 0 && (
                <div class="modeling-related">
                  <h4>関連リンク</h4>
                  <div>
                    {item.data.related.map((link) => (
                      <a href={link.href} {...externalAttrs(link.href)}>
                        {link.label}
                      </a>
                    ))}
                  </div>
                </div>
              )}
              <div class="social-row">
                {item.data.boothUrl && (
                  <a
                    href={item.data.boothUrl}
                    {...externalAttrs(item.data.boothUrl)}
                  >
                    BOOTH
                  </a>
                )}
                {item.data.youtubeUrl && (
                  <a
                    href={item.data.youtubeUrl}
                    {...externalAttrs(item.data.youtubeUrl)}
                  >
                    YouTube
                  </a>
                )}
                {item.data.tryOnUrl && (
                  <a
                    href={item.data.tryOnUrl}
                    {...externalAttrs(item.data.tryOnUrl)}
                  >
                    試着ワールド
                  </a>
                )}
                {item.data.xUrl && (
                  <a href={item.data.xUrl} {...externalAttrs(item.data.xUrl)}>
                    X
                  </a>
                )}
              </div>
            </article>
          ))
        }
      </div>
    </div>
  </section>
</BaseLayout>
