---
import BaseLayout from '@/layouts/BaseLayout.astro'
import youtubeFeed from '@/data/external/youtube-videos.json'
import { externalAttrs } from '@/utils/routes'

const channelUrl = youtubeFeed.channelUrl
const uploadsPlaylistUrl = youtubeFeed.uploadsPlaylistUrl
const uploadsEmbedUrl = youtubeFeed.uploadsEmbedUrl
const workVideos = youtubeFeed.videos
const formatDate = (value: string) =>
  value
    ? new Intl.DateTimeFormat('ja-JP', {
        dateStyle: 'medium',
        timeZone: 'Asia/Tokyo',
      }).format(new Date(value))
    : ''

const videoLinks = [
  {
    label: '全公開動画',
    href: uploadsPlaylistUrl,
    icon: 'i-lucide-list-video',
    text: '通常動画、公開済みのライブ配信アーカイブ、ショートをアップロード順に見られます。',
  },
  {
    label: 'ライブ',
    href: `${channelUrl}/streams`,
    icon: 'i-lucide-radio',
    text: '配信予定、現在のライブ、過去のライブ配信アーカイブを確認できます。',
  },
  {
    label: '動画',
    href: `${channelUrl}/videos`,
    icon: 'i-lucide-play-square',
    text: 'チャンネルの通常動画タブを開きます。',
  },
  {
    label: 'ショート',
    href: `${channelUrl}/shorts`,
    icon: 'i-lucide-smartphone',
    text: 'ショート動画だけをまとめて確認できます。',
  },
]
---

<BaseLayout
  title="動画"
  description="HattのYouTubeチャンネルで公開している動画、ライブ配信アーカイブ、ショート、VRChat向け作品動画をまとめたページです。"
  canonicalPath="/videos/"
>
  <section class="page-hero">
    <div class="section-inner video-hero">
      <div>
        <p class="hero-note">
          <span class="i-lucide-youtube" aria-hidden="true"></span>
          YouTube @hatt9241
        </p>
        <h1>動画</h1>
        <p class="lead">
          HattのYouTubeチャンネルで公開している動画をまとめて見られるページです。
          通常動画、ライブ配信アーカイブ、ショート、作品紹介動画まで、ホームページ上で再生できる入口をここに集約しています。
        </p>
        <div
          class="modeling-stats external-stats video-stats"
          aria-label="動画一覧"
        >
          <div>
            <span>全公開動画</span>
            <strong>サイト内再生</strong>
          </div>
          <div>
            <span>作品動画</span>
            <strong>{workVideos.length}本</strong>
          </div>
        </div>
        <div class="social-row video-hero-actions">
          <a href={uploadsPlaylistUrl} {...externalAttrs(uploadsPlaylistUrl)}>
            全動画プレイリスト
          </a>
          <a href={channelUrl} {...externalAttrs(channelUrl)}>
            チャンネルを開く
          </a>
        </div>
      </div>
      <figure class="video-player-card">
        <div class="video-player-frame">
          <iframe
            src={uploadsEmbedUrl}
            title="HattのYouTube全公開動画プレイリスト"
            loading="lazy"
            allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
            allowfullscreen></iframe>
        </div>
        <figcaption>
          通常動画、ライブ配信アーカイブ、ショートを含む全公開動画です。
        </figcaption>
      </figure>
    </div>
  </section>

  <section class="section-band" aria-labelledby="video-links-title">
    <div class="section-inner">
      <div class="section-heading">
        <div>
          <h2 id="video-links-title">チャンネル内の動画一覧</h2>
        </div>
        <p>ライブ配信やショートもYouTube側の各タブから確認できます。</p>
      </div>
      <div class="video-link-grid">
        {
          videoLinks.map((link) => (
            <a
              class="video-link-card"
              href={link.href}
              {...externalAttrs(link.href)}
            >
              <span class={link.icon} aria-hidden="true" />
              <strong>{link.label}</strong>
              <small>{link.text}</small>
            </a>
          ))
        }
      </div>
    </div>
  </section>

  <section class="section-band" aria-labelledby="work-videos-title">
    <div class="section-inner">
      <div class="section-heading">
        <div>
          <h2 id="work-videos-title">作品に紐づく動画</h2>
        </div>
        <p>
          全動画の中から、3D作品ページに紐づく紹介動画だけを補助的に並べています。
        </p>
      </div>
      <div class="external-grid external-grid--videos">
        {
          workVideos.map((video) => (
            <article class="external-card external-card--video">
              <a
                class="external-thumbnail"
                href={video.url}
                {...externalAttrs(video.url)}
                aria-label={`${video.title}をYouTubeで見る`}
              >
                <img src={video.thumbnailUrl} alt="" loading="lazy" />
                <span class="i-lucide-play" aria-hidden="true" />
              </a>
              <div>
                <div class="external-card-meta">
                  <span>{video.authorName}</span>
                  {video.publishedAt && (
                    <span>{formatDate(video.publishedAt)}</span>
                  )}
                </div>
                <h3>{video.title}</h3>
                <a
                  class="text-arrow"
                  href={video.url}
                  {...externalAttrs(video.url)}
                >
                  YouTubeで見る
                  <span class="i-lucide-arrow-up-right" aria-hidden="true" />
                </a>
              </div>
            </article>
          ))
        }
      </div>
    </div>
  </section>
</BaseLayout>
