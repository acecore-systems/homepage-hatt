---
import { getCollection } from 'astro:content'
import BaseLayout from '@/layouts/BaseLayout.astro'
import { externalAttrs } from '@/utils/routes'

const profileUrl = 'https://x.com/borubin'

type ArtItem = {
  id: string
  sourceUrl: string
  image: string
  title: string
  rank?: string
}

const getStatusId = (value: string) =>
  value.match(/(?:status\/|^x-)(\d{12,})/)?.[1]

const compareRank = (a: ArtItem, b: ArtItem) => {
  if (a.rank && b.rank) {
    return a.rank.length === b.rank.length
      ? b.rank.localeCompare(a.rank)
      : b.rank.length - a.rank.length
  }
  if (a.rank) return -1
  if (b.rank) return 1

  return b.id.localeCompare(a.id)
}

const getArtTitle = (sourceUrl: string, id: string) => {
  const statusId = getStatusId(sourceUrl)
  if (statusId) return `Xの絵投稿 ${statusId}`

  return sourceUrl || id
}

const artItems = (await getCollection('art'))
  .map((entry): ArtItem => {
    const sourceUrl = entry.data.sourceUrl.trim()
    const image = entry.data.image.trim()

    return {
      id: entry.id,
      sourceUrl,
      image,
      title: getArtTitle(sourceUrl, entry.id),
      rank: getStatusId(sourceUrl) ?? getStatusId(entry.id),
    }
  })
  .filter((item) => item.sourceUrl && item.image)
  .sort(compareRank)

const getArtTileClass = (index: number): string | undefined => {
  if (index % 13 === 0) return 'art-tile--large'
  if (index % 7 === 2 || index % 10 === 5) return 'art-tile--tall'
  if (index % 5 === 1 || index % 8 === 4) return 'art-tile--wide'

  return undefined
}
---

<BaseLayout
  title="絵"
  description="CMSで追加したHattの絵を、画像中心のギャラリーとして並べています。"
  showAnnouncement={false}
>
  <section class="section-band art-gallery-section" aria-labelledby="art-title">
    <div class="section-inner art-gallery-inner">
      <h1 id="art-title" class="sr-only">絵</h1>
      {
        artItems.length > 0 ? (
          <div class="art-grid">
            {artItems.map((item, index) => (
              <a
                class:list={['art-tile', getArtTileClass(index)]}
                href={item.sourceUrl}
                aria-label={`${item.title}の詳細を見る`}
                {...externalAttrs(item.sourceUrl)}
              >
                <img
                  src={item.image}
                  alt={item.title}
                  loading="lazy"
                  decoding="async"
                />
              </a>
            ))}
          </div>
        ) : (
          <div class="art-empty">
            <span class="i-lucide-image-plus" aria-hidden="true" />
            <h2>まだ掲載する絵がありません</h2>
            <p>CMSでURLと画像を追加すると、ここに絵が並びます。</p>
            <a href={profileUrl} {...externalAttrs(profileUrl)}>
              Xを見る
            </a>
          </div>
        )
      }
    </div>
  </section>
</BaseLayout>
