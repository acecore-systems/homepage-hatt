---
import BaseLayout from '@/layouts/BaseLayout.astro'
---

<BaseLayout
  title="講座申し込み管理"
  description="モデル制作講座の無料体験申し込みを確認する管理ページです。"
  robots="noindex,nofollow"
  manifestPath="/course-admin.webmanifest"
  themeColor="#151a24"
  pageClass="course-admin-page"
>
  <section class="course-admin-shell" data-course-admin>
    <div class="section-inner">
      <div class="course-admin-hero">
        <div>
          <p class="section-kicker">Course Admin</p>
          <h1>無料体験申し込み</h1>
          <p>新しい申し込みの確認、端末への通知登録、テスト通知を行えます。</p>
        </div>
        <div class="course-admin-status" data-admin-status role="status">
          パスコードを入力してください。
        </div>
      </div>

      <div class="course-admin-grid">
        <section class="course-admin-panel" aria-labelledby="admin-auth-title">
          <h2 id="admin-auth-title">認証</h2>
          <form class="course-admin-auth" data-admin-auth-form>
            <label for="course-admin-passcode">管理用パスコード</label>
            <div>
              <input
                id="course-admin-passcode"
                type="password"
                autocomplete="current-password"
                data-admin-passcode
                required
              />
              <button type="submit" class="primary-button">
                ログイン
                <span class="i-lucide-log-in" aria-hidden="true"></span>
              </button>
            </div>
          </form>
          <button type="button" class="secondary-button" data-admin-logout>
            保存を解除
            <span class="i-lucide-log-out" aria-hidden="true"></span>
          </button>
        </section>

        <section
          class="course-admin-panel"
          aria-labelledby="admin-notify-title"
        >
          <h2 id="admin-notify-title">通知</h2>
          <div class="course-admin-actions">
            <button type="button" class="primary-button" data-enable-push>
              通知を有効化
              <span class="i-lucide-bell-plus" aria-hidden="true"></span>
            </button>
            <button type="button" class="secondary-button" data-test-push>
              テスト通知
              <span class="i-lucide-send" aria-hidden="true"></span>
            </button>
          </div>
          <p data-push-status>
            この端末を登録すると、新規申し込み時に通知を受け取れます。
          </p>
        </section>
      </div>

      <section class="course-admin-panel course-admin-list-panel">
        <div class="course-admin-list-head">
          <div>
            <h2>申し込み一覧</h2>
            <p>最新の申し込みから表示します。</p>
          </div>
          <button type="button" class="secondary-button" data-refresh-signups>
            更新
            <span class="i-lucide-refresh-cw" aria-hidden="true"></span>
          </button>
        </div>
        <div class="course-admin-list" data-admin-signups></div>
      </section>
    </div>
  </section>

  <script is:inline>
    ;(() => {
      const root = document.querySelector('[data-course-admin]')
      if (!root) return

      const storageKey = 'hattCourseAdminPasscode'
      let passcode = window.localStorage.getItem(storageKey) || ''

      const authForm = root.querySelector('[data-admin-auth-form]')
      const passcodeInput = root.querySelector('[data-admin-passcode]')
      const logoutButton = root.querySelector('[data-admin-logout]')
      const enablePushButton = root.querySelector('[data-enable-push]')
      const testPushButton = root.querySelector('[data-test-push]')
      const refreshButton = root.querySelector('[data-refresh-signups]')
      const status = root.querySelector('[data-admin-status]')
      const pushStatus = root.querySelector('[data-push-status]')
      const signupsList = root.querySelector('[data-admin-signups]')

      if (passcodeInput) passcodeInput.value = passcode

      function setStatus(text, type) {
        if (!status) return
        status.textContent = text
        status.className = type
          ? `course-admin-status course-admin-status--${type}`
          : 'course-admin-status'
      }

      function setPushStatus(text, type) {
        if (!pushStatus) return
        pushStatus.textContent = text
        pushStatus.className = type
          ? `course-admin-help course-admin-help--${type}`
          : 'course-admin-help'
      }

      async function adminFetch(path, options = {}) {
        if (!passcode) throw new Error('管理用パスコードを入力してください。')

        const headers = new Headers(options.headers || {})
        headers.set('Accept', 'application/json')
        headers.set('Authorization', `Bearer ${passcode}`)
        if (options.body && !headers.has('Content-Type')) {
          headers.set('Content-Type', 'application/json')
        }

        const response = await fetch(path, { ...options, headers })
        const data = await response.json().catch(() => ({}))

        if (!response.ok || !data.ok) {
          throw new Error(data.message || '操作に失敗しました。')
        }

        return data
      }

      async function loadSignups() {
        if (!signupsList) return
        signupsList.textContent = ''
        const loading = document.createElement('p')
        loading.className = 'course-admin-empty'
        loading.textContent = '読み込んでいます。'
        signupsList.append(loading)

        try {
          const data = await adminFetch('/api/course-admin/signups?limit=50')
          renderSignups(data.signups || [])
          setStatus('申し込み一覧を更新しました。', 'success')
        } catch (error) {
          renderSignups([])
          setStatus(
            error instanceof Error ? error.message : '読み込みに失敗しました。',
            'error',
          )
        }
      }

      function renderSignups(signups) {
        if (!signupsList) return
        signupsList.textContent = ''

        if (!signups.length) {
          const empty = document.createElement('p')
          empty.className = 'course-admin-empty'
          empty.textContent = '申し込みはまだありません。'
          signupsList.append(empty)
          return
        }

        for (const signup of signups) {
          const article = document.createElement('article')
          article.className = 'course-admin-signup'

          const header = document.createElement('div')
          header.className = 'course-admin-signup-head'

          const title = document.createElement('h3')
          title.textContent = signup.name || '名前なし'

          const time = document.createElement('time')
          time.dateTime = signup.createdAt || ''
          time.textContent = formatDate(signup.createdAt)

          const statusBadge = document.createElement('span')
          statusBadge.textContent = signup.status || 'new'

          header.append(title, time, statusBadge)

          const contact = document.createElement('p')
          contact.className = 'course-admin-contact'
          contact.textContent = signup.contact || ''

          const preferred = document.createElement('p')
          preferred.className = 'course-admin-preferred'
          preferred.textContent = `希望日時: ${signup.preferredTime || ''}`

          const goal = document.createElement('p')
          goal.className = 'course-admin-goal'
          goal.textContent = signup.goal || ''

          article.append(header, contact, preferred, goal)
          signupsList.append(article)
        }
      }

      async function enableNotifications() {
        if (!('serviceWorker' in navigator)) {
          setPushStatus(
            'このブラウザはService Workerに対応していません。',
            'error',
          )
          return
        }

        if (!('Notification' in window) || !('PushManager' in window)) {
          setPushStatus('このブラウザはPush通知に対応していません。', 'error')
          return
        }

        setPushStatus('通知登録を準備しています。')

        try {
          const config = await adminFetch('/api/course-admin/push-config')
          const registration = await navigator.serviceWorker.register(
            '/notify-service-worker.js',
            { scope: '/' },
          )

          let permission = Notification.permission
          if (permission === 'default') {
            permission = await Notification.requestPermission()
          }

          if (permission !== 'granted') {
            setPushStatus('通知が許可されませんでした。', 'error')
            return
          }

          let subscription = await registration.pushManager.getSubscription()
          if (!subscription) {
            subscription = await registration.pushManager.subscribe({
              userVisibleOnly: true,
              applicationServerKey: base64UrlToUint8Array(config.publicKey),
            })
          }

          await adminFetch('/api/course-admin/push-subscriptions', {
            method: 'POST',
            body: JSON.stringify({
              subscription: subscription.toJSON(),
              deviceLabel: buildDeviceLabel(),
            }),
          })

          setPushStatus('この端末の通知を有効化しました。', 'success')
        } catch (error) {
          setPushStatus(
            error instanceof Error ? error.message : '通知登録に失敗しました。',
            'error',
          )
        }
      }

      async function sendTestPush() {
        setPushStatus('テスト通知を送信しています。')

        try {
          const data = await adminFetch('/api/course-admin/test-push', {
            method: 'POST',
          })
          setPushStatus(data.message || 'テスト通知を送信しました。', 'success')
        } catch (error) {
          setPushStatus(
            error instanceof Error
              ? error.message
              : 'テスト通知を送信できません。',
            'error',
          )
        }
      }

      function buildDeviceLabel() {
        const platform = navigator.platform || 'unknown platform'
        const userAgent = navigator.userAgent.includes('Mobile')
          ? 'mobile'
          : 'desktop'

        return `${platform} / ${userAgent}`
      }

      function base64UrlToUint8Array(value) {
        const padding = '='.repeat((4 - (value.length % 4)) % 4)
        const base64 = `${value}${padding}`
          .replace(/-/g, '+')
          .replace(/_/g, '/')
        const rawData = window.atob(base64)
        const output = new Uint8Array(rawData.length)

        for (let index = 0; index < rawData.length; index += 1) {
          output[index] = rawData.charCodeAt(index)
        }

        return output
      }

      function formatDate(value) {
        const date = new Date(value)
        if (Number.isNaN(date.getTime())) return ''

        return new Intl.DateTimeFormat('ja-JP', {
          timeZone: 'Asia/Tokyo',
          year: 'numeric',
          month: 'short',
          day: 'numeric',
          hour: '2-digit',
          minute: '2-digit',
        }).format(date)
      }

      authForm?.addEventListener('submit', (event) => {
        event.preventDefault()
        passcode = String(passcodeInput?.value || '').trim()
        if (!passcode) {
          setStatus('管理用パスコードを入力してください。', 'error')
          return
        }

        window.localStorage.setItem(storageKey, passcode)
        setStatus('ログインしました。', 'success')
        void loadSignups()
      })

      logoutButton?.addEventListener('click', () => {
        passcode = ''
        window.localStorage.removeItem(storageKey)
        if (passcodeInput) passcodeInput.value = ''
        renderSignups([])
        setStatus('保存したパスコードを解除しました。')
      })

      enablePushButton?.addEventListener('click', () => {
        void enableNotifications()
      })

      testPushButton?.addEventListener('click', () => {
        void sendTestPush()
      })

      refreshButton?.addEventListener('click', () => {
        void loadSignups()
      })

      if (passcode) {
        setStatus('保存済みのパスコードで読み込みます。')
        void loadSignups()
      }
    })()
  </script>
</BaseLayout>
