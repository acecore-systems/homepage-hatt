---
import ArticleCard from '@/components/ArticleCard.astro'
import CampaignNotices from '@/components/CampaignNotices.astro'
import BaseLayout from '@/layouts/BaseLayout.astro'
import novelsFeed from '@/data/external/novels.json'
import youtubeFeed from '@/data/external/youtube-videos.json'
import {
  getArchiveStats,
  getPosts,
  getSiteConfig,
  getTagMap,
  getTagStats,
} from '@/utils/blog'
import { externalAttrs } from '@/utils/routes'

const site = await getSiteConfig()
const posts = await getPosts()
const tagMap = await getTagMap()
const tagStats = await getTagStats()
const archiveStats = await getArchiveStats()
const latestPosts = posts.slice(0, 2)
const featuredPillars = site.homePillars
const homeTagStats = tagStats.slice(0, 8)
const novelWorks = novelsFeed.works
const latestNovel = novelWorks[0]
const novelStats = {
  total: novelWorks.length,
  serial: novelWorks.filter((work) => work.type === 'serial').length,
  short: novelWorks.filter((work) => work.type === 'short').length,
}
const modelingVideoCount = youtubeFeed.videos.filter((video) =>
  video.source.includes('modeling'),
).length
const novelLinks = [
  { label: '作品一覧', href: '/novels/', icon: 'i-lucide-library' },
  {
    label: '作者ページ',
    href: novelsFeed.authorUrl,
    icon: 'i-lucide-user-round',
  },
  ...(latestNovel
    ? [
        {
          label: '最新作',
          href: latestNovel.url,
          icon: 'i-lucide-sparkles',
        },
      ]
    : []),
]
const modelingLinks = [
  {
    label: '無料体験',
    href: '/modeling-course/',
    icon: 'i-lucide-graduation-cap',
  },
  { label: '作品一覧', href: '/modeling/', icon: 'i-lucide-box' },
  { label: '動画一覧', href: '/videos/', icon: 'i-lucide-square-play' },
  {
    label: 'BOOTH',
    href: 'https://vetumheberehama.booth.pm/',
    icon: 'i-lucide-shopping-bag',
  },
  {
    label: 'YouTube',
    href: 'https://www.youtube.com/@hatt9241',
    icon: 'i-lucide-youtube',
  },
]
---

<BaseLayout
  title={site.name}
  description={site.description}
  image={site.cover}
  pageClass="home-page"
>
  <section class="home-hero">
    <div class="section-inner">
      <div class="home-hero-top">
        <div class="home-hero-copy">
          <h1>いろいろ描いてます</h1>
          <p>
            鉛筆やペンで描いたイラストを中心に、創作の記録をのんびり公開しています。気ままに見てもらえるとうれしいです。
          </p>
          <div class="button-row">
            <a
              class="primary-button"
              href="/art/"
              data-hatt-event="cta_click"
              data-hatt-label="hero_art"
              data-hatt-location="home_hero"
            >
              絵を見る
              <span class="i-lucide-arrow-right" aria-hidden="true"></span>
            </a>
          </div>
        </div>
        <div class="home-hero-sketch" aria-hidden="true">
          <span class="home-hero-tape"></span>
          <img src="/uploads/hatt/novel-desert-boy.png" alt="" />
        </div>
      </div>

      <div class="home-pillar-board" aria-label="制作しているもの">
        {
          featuredPillars.map((pillar) => (
            <article class={`home-pillar home-pillar--${pillar.id}`}>
              <div class="home-pillar-image">
                <img src={pillar.image} alt="" />
              </div>
              <div class="home-pillar-body">
                <div class="home-pillar-head">
                  <span class="home-pillar-icon" aria-hidden="true">
                    <span
                      class={
                        pillar.id === 'picture'
                          ? 'i-lucide-pencil'
                          : pillar.id === 'novel'
                            ? 'i-lucide-book-open'
                            : 'i-lucide-box'
                      }
                    />
                  </span>
                  <div>
                    <h2>{pillar.label}</h2>
                    <p>{pillar.eyebrow}</p>
                  </div>
                </div>
                <h3>{pillar.title}</h3>
                <p>{pillar.description}</p>
                {pillar.id === 'novel' ? (
                  <>
                    <div class="home-pillar-actions">
                      {novelLinks.map((link) => (
                        <a
                          href={link.href}
                          {...externalAttrs(link.href)}
                          data-hatt-event="novel_link_click"
                          data-hatt-label={link.label}
                          data-hatt-location="home_pillar_novel"
                        >
                          <span class={link.icon} aria-hidden="true" />
                          {link.label}
                        </a>
                      ))}
                    </div>
                    <div class="home-pillar-stats" aria-label="小説作品の概要">
                      <div>
                        <span>公開作品</span>
                        <strong>{novelStats.total}作</strong>
                      </div>
                      <div>
                        <span>連載</span>
                        <strong>{novelStats.serial}作</strong>
                      </div>
                      <div>
                        <span>短編</span>
                        <strong>{novelStats.short}作</strong>
                      </div>
                    </div>
                  </>
                ) : pillar.id === 'modeling' ? (
                  <>
                    <div class="home-pillar-actions">
                      {modelingLinks.map((link) => (
                        <a
                          href={link.href}
                          {...externalAttrs(link.href)}
                          data-hatt-event="modeling_link_click"
                          data-hatt-label={link.label}
                          data-hatt-location="home_pillar_modeling"
                        >
                          <span class={link.icon} aria-hidden="true" />
                          {link.label}
                        </a>
                      ))}
                    </div>
                    <div
                      class="home-pillar-stats"
                      aria-label="モデリング活動の概要"
                    >
                      <div>
                        <span>アバター</span>
                        <strong>9種</strong>
                      </div>
                      <div>
                        <span>ギミック</span>
                        <strong>5種</strong>
                      </div>
                      <div>
                        <span>公開作品</span>
                        <strong>14点</strong>
                      </div>
                      <div>
                        <span>動画</span>
                        <strong>{modelingVideoCount}本</strong>
                      </div>
                    </div>
                  </>
                ) : (
                  <a
                    class="home-pillar-button"
                    href={pillar.href}
                    {...externalAttrs(pillar.href)}
                    data-hatt-event="pillar_click"
                    data-hatt-label={pillar.id}
                    data-hatt-location="home_pillars"
                  >
                    {pillar.cta}
                    <span class="i-lucide-arrow-right" aria-hidden="true" />
                  </a>
                )}
              </div>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <section class="home-course-strip" aria-labelledby="home-course-title">
    <div class="section-inner home-course-strip-inner">
      <div class="home-course-strip-copy">
        <span class="i-lucide-graduation-cap" aria-hidden="true"></span>
        <div>
          <p>VRChatモデル制作・Blender基礎・Unity導入</p>
          <h2 id="home-course-title">モデル制作の無料体験を受付中</h2>
        </div>
      </div>
      <p>
        30分のオンライン相談で、作りたいものと最初に詰まりやすい工程を整理します。
      </p>
      <div class="home-course-strip-actions">
        <a
          class="primary-button"
          href="/modeling-course/"
          data-hatt-event="cta_click"
          data-hatt-label="home_course_trial"
          data-hatt-location="home_course_strip"
        >
          無料体験を見る
          <span class="i-lucide-arrow-right" aria-hidden="true"></span>
        </a>
      </div>
    </div>
  </section>

  <CampaignNotices placement="home-after-hero" />

  <section class="home-latest" aria-labelledby="latest-title">
    <div class="section-inner">
      <div class="section-heading">
        <div>
          <h2 id="latest-title">最新の記事</h2>
        </div>
        <a class="chip-link" href="/blog/"
          >すべての記事を見る
          <span class="i-lucide-arrow-right" aria-hidden="true"></span></a
        >
      </div>
      <div class="home-latest-layout">
        <div class="article-grid">
          {
            latestPosts.map((post) => (
              <ArticleCard post={post} tagMap={tagMap} compact />
            ))
          }
        </div>
        <aside class="home-latest-side" aria-label="ブログナビゲーション">
          <section>
            <div class="home-side-heading">
              <h3>タグから探す</h3>
            </div>
            <div class="home-tag-cloud">
              {
                homeTagStats.map((tag) => (
                  <a
                    href={`/blog/tag/${tag.slug}/`}
                    data-hatt-event="tag_click"
                    data-hatt-label={tag.slug}
                    data-hatt-location="home_sidebar"
                  >
                    {tag.name}
                  </a>
                ))
              }
            </div>
          </section>
          <section>
            <div class="home-side-heading">
              <h3>アーカイブ</h3>
            </div>
            <label class="sr-only" for="home-archive-select">月を選択</label>
            <select
              id="home-archive-select"
              class="home-archive-select"
              data-home-archive-select
            >
              <option value="">月を選択</option>
              {
                archiveStats.map((archive) => (
                  <option value={`/blog/archive/${archive.month}/`}>
                    {archive.label}
                  </option>
                ))
              }
            </select>
          </section>
        </aside>
      </div>
    </div>
  </section>

  <script>
    const homeArchiveSelect = document.querySelector<HTMLSelectElement>(
      '[data-home-archive-select]',
    )

    homeArchiveSelect?.addEventListener('change', () => {
      if (homeArchiveSelect.value) {
        window.location.href = homeArchiveSelect.value
      }
    })
  </script>
</BaseLayout>
