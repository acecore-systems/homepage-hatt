---
import BaseLayout from '@/layouts/BaseLayout.astro'
---

<BaseLayout
  title="記事を検索"
  description="Hattのブログ記事をキーワードで検索できます。"
  robots="noindex,follow"
  breadcrumbItems={[
    { name: 'ブログ', item: '/blog/' },
    { name: '記事を検索', item: '/blog/search/' },
  ]}
>
  <section class="page-hero">
    <div class="narrow-page">
      <h1>記事を検索</h1>
      <p class="lead">絵、小説、モデリングの記事を検索できます。</p>
    </div>
  </section>

  <section class="section-band">
    <div class="narrow-page search-box">
      <form class="search-form" id="search-form">
        <label class="sr-only" for="search-input">検索キーワード</label>
        <input
          id="search-input"
          name="q"
          type="search"
          placeholder="キーワードを入力..."
          autocomplete="off"
        />
        <button class="primary-button" type="submit">
          検索
          <span class="i-lucide-search" aria-hidden="true"></span>
        </button>
      </form>
      <div class="search-results" id="search-results" aria-live="polite">
        <p class="empty-state">キーワードを入力してください。</p>
      </div>
    </div>
  </section>

  <script is:inline>
    const form = document.querySelector('#search-form')
    const input = document.querySelector('#search-input')
    const results = document.querySelector('#search-results')

    function clearResults() {
      results?.replaceChildren()
    }

    function setMessage(message, withBlogLink = false) {
      clearResults()
      const paragraph = document.createElement('p')
      paragraph.className = 'empty-state'
      paragraph.textContent = message

      if (withBlogLink) {
        paragraph.append(' ')
        const link = document.createElement('a')
        link.href = '/blog/'
        link.textContent = 'ブログ一覧へ'
        paragraph.append(link)
      }

      results?.append(paragraph)
    }

    function textFromExcerpt(excerpt) {
      return String(excerpt ?? '')
        .replace(/<[^>]*>/g, '')
        .replace(/\s+/g, ' ')
        .trim()
    }

    function appendResult(row) {
      const link = document.createElement('a')
      link.className = 'search-result'
      link.href = row.url

      const title = document.createElement('h2')
      title.textContent = row.meta?.title ?? '無題の記事'

      const excerpt = document.createElement('p')
      excerpt.textContent = textFromExcerpt(row.excerpt)

      link.append(title, excerpt)
      results?.append(link)
    }

    async function runSearch(query) {
      setMessage('検索を読み込んでいます...')
      try {
        const pagefind = await import(
          /* @vite-ignore */ '/pagefind/pagefind.js'
        )
        const search = await pagefind.search(query)
        const rows = await Promise.all(
          search.results.slice(0, 10).map((result) => result.data()),
        )

        if (rows.length === 0) {
          setMessage('一致する記事が見つかりませんでした。', true)
          return
        }

        clearResults()
        rows.forEach(appendResult)
      } catch {
        setMessage(
          '検索インデックスはビルド後に有効になります。ブログ一覧もお試しください。',
          true,
        )
      }
    }

    form?.addEventListener('submit', (event) => {
      event.preventDefault()
      const query = input?.value?.trim()
      if (!query) {
        setMessage('キーワードを入力してください。')
        return
      }
      const url = new URL(window.location.href)
      url.searchParams.set('q', query)
      window.history.replaceState({}, '', url)
      runSearch(query)
    })

    const initialQuery = new URLSearchParams(window.location.search)
      .get('q')
      ?.trim()

    if (initialQuery) {
      input.value = initialQuery
      runSearch(initialQuery)
    }
  </script>
</BaseLayout>
