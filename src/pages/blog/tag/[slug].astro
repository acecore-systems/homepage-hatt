---
import ArticleCard from '@/components/ArticleCard.astro'
import BlogSidebar from '@/components/BlogSidebar.astro'
import BaseLayout from '@/layouts/BaseLayout.astro'
import {
  getArchiveStats,
  getAuthors,
  getPosts,
  getPostsByTag,
  getTagMap,
  getTags,
  getTagStats,
} from '@/utils/blog'

export async function getStaticPaths() {
  const tags = await getTags()
  return tags.map((tag) => ({
    params: { slug: tag.data.slug },
    props: { tag },
  }))
}

const { tag } = Astro.props
const posts = await getPosts()
const filteredPosts = getPostsByTag(posts, tag.data.id)
const tagMap = await getTagMap()
const tagStats = await getTagStats()
const archives = await getArchiveStats()
const authors = await getAuthors()
---

<BaseLayout
  title={`タグ: ${tag.data.name}`}
  description={tag.data.description ?? `${tag.data.name}の記事一覧です。`}
  robots="noindex,follow"
  breadcrumbItems={[
    { name: 'ブログ', item: '/blog/' },
    { name: 'タグ一覧', item: '/blog/tag/' },
    { name: tag.data.name, item: `/blog/tag/${tag.data.slug}/` },
  ]}
>
  <section class="blog-hero">
    <div class="blog-shell" style="padding-bottom: 0;">
      <div class="blog-title">
        <div>
          <h1>タグ: {tag.data.name}</h1>
          <p class="lead">{tag.data.description}</p>
        </div>
        <a class="chip-link" href="/blog/tag/">タグ一覧へ</a>
      </div>
      <div aria-hidden="true"></div>
    </div>
  </section>

  <div class="blog-shell">
    <div class="blog-list">
      {filteredPosts.map((post) => <ArticleCard post={post} tagMap={tagMap} />)}
      {
        filteredPosts.length === 0 && (
          <p class="empty-state">記事の準備中です。</p>
        )
      }
    </div>
    <BlogSidebar tags={tagStats} archives={archives} authors={authors} />
  </div>
</BaseLayout>
