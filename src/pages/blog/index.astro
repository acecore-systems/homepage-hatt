---
import AdUnit from '@/components/AdUnit.astro'
import ArticleCard from '@/components/ArticleCard.astro'
import BlogSidebar from '@/components/BlogSidebar.astro'
import CampaignNotices from '@/components/CampaignNotices.astro'
import Pagination from '@/components/Pagination.astro'
import BaseLayout from '@/layouts/BaseLayout.astro'
import {
  getBlogPageCount,
  getArchiveStats,
  getAuthors,
  getPaginatedPosts,
  getPosts,
  getTagMap,
  getTagStats,
} from '@/utils/blog'

const posts = await getPosts()
const currentPage = 1
const totalPages = getBlogPageCount(posts)
const pagePosts = getPaginatedPosts(posts, currentPage)
const tagMap = await getTagMap()
const tagStats = await getTagStats()
const archives = await getArchiveStats()
const authors = await getAuthors()
---

<BaseLayout
  title="ブログ"
  description="Hattの絵、小説、モデリングに関する記事一覧です。"
>
  <section class="blog-hero">
    <div class="blog-shell" style="padding-bottom: 0;">
      <div class="blog-title">
        <div>
          <h1>ブログ</h1>
          <p class="lead">絵、小説、モデリングの制作記録を置いています。</p>
        </div>
        <a class="primary-button" href="/blog/search/">
          記事を検索
          <span class="i-lucide-search" aria-hidden="true"></span>
        </a>
      </div>
      <div aria-hidden="true"></div>
    </div>
  </section>

  <CampaignNotices placement="blog-after-hero" />

  <div class="blog-shell">
    <div>
      <div class="tag-list" style="margin-bottom: 18px;">
        {
          tagStats.map((tag) => (
            <a href={`/blog/tag/${tag.slug}/`}>#{tag.name}</a>
          ))
        }
      </div>
      <div class="blog-list">
        {pagePosts.map((post) => <ArticleCard post={post} tagMap={tagMap} />)}
      </div>
      <Pagination currentPage={currentPage} totalPages={totalPages} />
      <AdUnit placement="list" />
    </div>
    <BlogSidebar tags={tagStats} archives={archives} authors={authors} />
  </div>
</BaseLayout>
