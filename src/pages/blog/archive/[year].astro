---
import ArticleCard from '@/components/ArticleCard.astro'
import BlogSidebar from '@/components/BlogSidebar.astro'
import BaseLayout from '@/layouts/BaseLayout.astro'
import {
  getArchiveStats,
  getAuthors,
  getPosts,
  getPostsByYear,
  getTagMap,
  getTagStats,
} from '@/utils/blog'

export async function getStaticPaths() {
  const archives = await getArchiveStats()
  return archives.map((archive) => ({
    params: { year: archive.year.toString() },
  }))
}

const year = Number(Astro.params.year)
const posts = await getPosts()
const filteredPosts = getPostsByYear(posts, year)
const tagMap = await getTagMap()
const tagStats = await getTagStats()
const archives = await getArchiveStats()
const authors = await getAuthors()
---

<BaseLayout
  title={`${year}年の記事`}
  description={`${year}年に公開されたHattの記事一覧です。`}
  robots="noindex,follow"
  breadcrumbItems={[
    { name: 'ブログ', item: '/blog/' },
    { name: 'アーカイブ', item: '/blog/archive/' },
    { name: `${year}年`, item: `/blog/archive/${year}/` },
  ]}
>
  <section class="blog-hero">
    <div class="blog-shell" style="padding-bottom: 0;">
      <div class="blog-title">
        <div>
          <h1>{year}年の記事</h1>
          <p class="lead">{filteredPosts.length}件の記事があります。</p>
        </div>
        <a class="chip-link" href="/blog/archive/">アーカイブ一覧へ</a>
      </div>
      <div aria-hidden="true"></div>
    </div>
  </section>

  <div class="blog-shell">
    <div class="blog-list">
      {filteredPosts.map((post) => <ArticleCard post={post} tagMap={tagMap} />)}
    </div>
    <BlogSidebar tags={tagStats} archives={archives} authors={authors} />
  </div>
</BaseLayout>
