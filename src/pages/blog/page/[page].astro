---
import AdUnit from '@/components/AdUnit.astro'
import ArticleCard from '@/components/ArticleCard.astro'
import BlogSidebar from '@/components/BlogSidebar.astro'
import Pagination from '@/components/Pagination.astro'
import BaseLayout from '@/layouts/BaseLayout.astro'
import {
  getArchiveStats,
  getAuthors,
  getBlogPageCount,
  getPaginatedPosts,
  getPosts,
  getTagMap,
  getTagStats,
} from '@/utils/blog'

export async function getStaticPaths() {
  const posts = await getPosts()
  const totalPages = getBlogPageCount(posts)

  return Array.from({ length: Math.max(0, totalPages - 1) }, (_, index) => {
    const page = index + 2
    return { params: { page: String(page) } }
  })
}

const posts = await getPosts()
const currentPage = Number(Astro.params.page)
const totalPages = getBlogPageCount(posts)
const pagePosts = getPaginatedPosts(posts, currentPage)
const tagMap = await getTagMap()
const tagStats = await getTagStats()
const archives = await getArchiveStats()
const authors = await getAuthors()
---

<BaseLayout
  title={`ブログ ${currentPage}ページ目`}
  description={`Hattの絵、小説、モデリングに関する記事一覧 ${currentPage}ページ目です。`}
  robots="noindex,follow"
  breadcrumbItems={[
    { name: 'ブログ', item: '/blog/' },
    { name: `${currentPage}ページ目`, item: `/blog/page/${currentPage}/` },
  ]}
>
  <section class="blog-hero">
    <div class="blog-shell" style="padding-bottom: 0;">
      <div class="blog-title">
        <div>
          <h1>ブログ</h1>
          <p class="lead">
            絵、小説、モデリングの制作記録を置いています。{currentPage}ページ目
            です。
          </p>
        </div>
        <a class="chip-link" href="/blog/">最新記事へ</a>
      </div>
      <div aria-hidden="true"></div>
    </div>
  </section>

  <div class="blog-shell">
    <div>
      <div class="blog-list">
        {pagePosts.map((post) => <ArticleCard post={post} tagMap={tagMap} />)}
      </div>
      <Pagination currentPage={currentPage} totalPages={totalPages} />
      <AdUnit placement="list" />
    </div>
    <BlogSidebar tags={tagStats} archives={archives} authors={authors} />
  </div>
</BaseLayout>
