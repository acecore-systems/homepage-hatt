---
import '@fontsource/noto-sans-jp/400.css'
import '@fontsource/noto-sans-jp/500.css'
import '@fontsource/noto-sans-jp/700.css'
import '@fontsource/noto-sans-jp/800.css'
import 'virtual:uno.css'
import '@/styles/global.css'

import Footer from '@/components/Footer.astro'
import Header from '@/components/Header.astro'
import { getSiteConfig } from '@/utils/blog'

type Props = {
  title?: string
  description?: string
  image?: string
  pageClass?: string
}

const site = await getSiteConfig()
const title = Astro.props.title ?? site.name
const description = Astro.props.description ?? site.description
const pageTitle = title === site.name ? title : `${title} | ${site.name}`
const pageClass = Astro.props.pageClass ?? ''
const toAbsolute = (path: string) =>
  /^https?:\/\//.test(path)
    ? path
    : new URL(path, Astro.site ?? Astro.url).toString()
const ogImage = toAbsolute(Astro.props.image ?? site.cover)
const canonical = new URL(
  Astro.url.pathname,
  Astro.site ?? Astro.url,
).toString()
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="format-detection" content="telephone=no" />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <link rel="icon" type="image/png" href={site.icon} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={site.name} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta name="twitter:card" content="summary_large_image" />
    {
      site.adsenseClientId && (
        <script
          async
          crossorigin="anonymous"
          src={`https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=${site.adsenseClientId}`}
        />
      )
    }
  </head>
  <body class={pageClass}>
    <a class="skip-link" href="#main-content">本文へスキップ</a>
    <Header site={site} />
    <main id="main-content" data-pagefind-body>
      <slot />
    </main>
    <Footer site={site} />
  </body>
</html>
