/*
  Cache-Control: public, max-age=0, must-revalidate
  X-Content-Type-Options: nosniff
  X-Robots-Tag: all
  Referrer-Policy: strict-origin-when-cross-origin
  X-Frame-Options: SAMEORIGIN
  Permissions-Policy: camera=(), geolocation=(), microphone=(), payment=(), usb=(), interest-cohort=()
  Cross-Origin-Opener-Policy: same-origin-allow-popups
  Strict-Transport-Security: max-age=63072000; includeSubDomains; preload

/_astro/*
  Cache-Control: public, max-age=31536000, immutable

/uploads/*
  Cache-Control: public, max-age=604800, stale-while-revalidate=86400

/pagefind/*
  Cache-Control: public, max-age=0, must-revalidate

/rss.xml
  Cache-Control: public, max-age=3600

/sitemap-index.xml
  Cache-Control: public, max-age=3600

/sitemap-*.xml
  Cache-Control: public, max-age=3600

/admin/*
  ! Content-Security-Policy
  ! Cross-Origin-Opener-Policy
  ! X-Robots-Tag
  X-Robots-Tag: noindex, nofollow
  Cache-Control: public, max-age=0, must-revalidate
  Cross-Origin-Opener-Policy: same-origin-allow-popups
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline' https://unpkg.com; style-src 'self' 'unsafe-inline' https://unpkg.com https://fonts.googleapis.com; img-src 'self' data: blob: https://*; font-src 'self' data: https://unpkg.com https://fonts.gstatic.com; media-src blob:; connect-src 'self' blob: data: https://unpkg.com https://api.github.com https://github.com https://www.githubstatus.com https://*.githubusercontent.com https://sveltia-cms-auth.sparkling-tree-7cef.workers.dev; frame-src 'self' blob: https://github.com; worker-src blob:; object-src 'none'; frame-ancestors 'self'; base-uri 'self'; form-action 'self' https://github.com https://sveltia-cms-auth.sparkling-tree-7cef.workers.dev

/admin/config.yml
  Content-Type: application/yaml; charset=utf-8
  Cache-Control: no-store
